# FitoDesk 환경 변수

# PostgreSQL 연결 문자열 (Neon, Supabase, 로컬 등)
DATABASE_URL=postgresql://user:password@localhost:5432/fitodesk

# Google Gemini API 키 (자연어 파싱)
GEMINI_API_KEY=

# Web Push VAPID 키 쌍 (npx web-push generate-vapid-keys 로 생성)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:sangyoung.yun@fitogether.com

# ───────────────────────────────────────────────────
# ERP 연동 — erp.fitogether.com 세션 토큰
#
# 발급 방법:
#   1. Chrome에서 https://erp.fitogether.com 로그인
#   2. 개발자 도구(F12) → Application → Cookies → erp.fitogether.com
#   3. __Secure-authjs.session-token 값을 복사해 아래에 붙여넣기
#
# 주의: 토큰 만료(~30일) 시 재발급 필요. 만료되면 ERP 패널에 "세션 만료" 표시됨.
ERP_SESSION_TOKEN=
