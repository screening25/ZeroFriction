datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Schedule {
  id             String   @id @default(uuid())
  title          String
  date           String   // YYYY-MM-DD
  time           String?  // HH:MM
  category       String   // WORK, PERSONAL, HEALTH, ETC
  memo           String?  // 상세 메모
  completed      Boolean  @default(false)
  notifyOffset   Int      @default(10) // 알림 시간 (분 단위, -1은 알림 끄기)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PolicyTracker {
  id            String   @id @default(uuid())
  title         String
  effectiveDate String   // YYYY-MM-DD
  content       String   // 상세 규정 내용
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 모든 기기(APK·데스크톱·웹)가 공유하는 단일 앱 상태 저장소.
// 기존 localStorage 키(universal_records, archived_records, zero_settings, zero_activities)를
// 그대로 key 로 사용하고, 값(배열/객체)을 value(Json)에 저장한다 — 클라우드 localStorage.
model AppState {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

